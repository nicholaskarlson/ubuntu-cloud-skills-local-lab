# Book 2 local-only environment example.
#
# Copy this file to .env.local when a lesson asks you to configure your own lab:
#
#   cp book2/env.example .env.local
#
# .env.local is ignored by Git. Do not commit local machine details, passwords,
# private keys, provider tokens, customer data, or credential screenshots.

# Default Book 2 mode. The core path is LAN-first.
BOOK2_MODE=lan

# Private LAN host or IP for the future server machine.
# Example private IPv4 ranges include 10.x.x.x, 172.16-31.x.x, and 192.168.x.x.
BOOK2_HOST=10.0.0.113

# Local account name on the future server machine.
# Use a normal non-root user for the learning path.
BOOK2_USER=nick

# SSH port. The default is 22.
BOOK2_SSH_PORT=22

# Optional future fields. Leave blank for the LAN-first path.
BOOK2_DOMAIN=
BOOK2_PUBLIC_URL=
BOOK2_IDENTITY_FILE=
